{
  "name": "dex-uniswap-v2-monorepo",
  "private": true,
  "workspaces": [
    "v2-core",
    "v2-periphery"
  ],
  "scripts": {
    "setup": "./scripts/setup.sh",
    "setup:interface": "./scripts/setup-interface.sh",
    "test:all": "./scripts/test-all.sh",
    "compile:core": "cd v2-core && npm run compile",
    "compile:periphery": "cd v2-periphery && npm run compile",
    "compile:all": "npm run compile:core && npm run compile:periphery",
    "deploy:testnet": "node ./scripts/deploy-dex-v2.js",
    "deploy:test-tokens": "node ./scripts/deploy-test-tokens.js",
    "seed:liquidity": "node ./scripts/seed-liquidity-v2.js",
    "swap:preflight": "node ./scripts/kasane-swap-preflight.js",
    "frontend:start": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:test": "cd frontend && npm run test",
    "token-indexer:run": "node ./scripts/token-indexer/runTokenSearchIndexer.mjs",
    "token-indexer:test": "node --test ./scripts/token-indexer/test/*.test.mjs"
  },
  "dependencies": {
    "viem": "^2.38.5"
  }
}
