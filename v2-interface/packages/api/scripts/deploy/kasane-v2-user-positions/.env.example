# Kasane indexer env (single entrypoint for token/pool + optional user LP positions)
INDEXER_CHAIN_ID=4801360
INDEXER_RPC_URL=https://rpc-testnet.kasane.network
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Optional. Defaults shown below.
INDEXER_V2_FACTORY_ADDRESS=0x697c9e9ea0686515fea69f526f85b48d8569ec86
INDEXER_V2_MAX_PAIRS=200
INDEXER_STABLE_TOKEN_ADDRESSES=0x6052dFc3D327bbe13D182e31a207e4c82cf34a5e

# Optional: comma-separated wallet list to also update v2_user_lp_positions
INDEXER_V2_USER_WALLET_ADDRESSES=0x909D57e94B8f385Ce9389d6B88Dc6dec6fb5F7C0

# Optional: custom token list URL(s). If empty, runner auto-builds list from discovered pools.
INDEXER_TOKEN_LIST_URLS=

# Optional: native token USD price source (Binance 24h ticker).
# Defaults: ICPUSDT, and updates both WICP + 0xeeee.. pseudo-native rows.
INDEXER_NATIVE_PRICE_SYMBOL=ICPUSDT
INDEXER_NATIVE_PRICE_TOKEN_ADDRESSES=0x4dfc4b47164ac7d42507bf1f9cca1bcddc0eee79,0xeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee

# Optional: per-pool 24h volume clamp (USD) to suppress abnormal spikes.
INDEXER_MAX_POOL_VOLUME_24H_USD=10000000
